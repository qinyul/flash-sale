  },
  "item": [
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Gaming Laptop\",\n    \"base_price\": 1200.50,\n    \"quantity\": 100\n}"
            },
            "url": {
              "raw": "{{base_url}}/products",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products"
              ]
            },
            "description": "Creates a new product with initial stock."
          },
          "response": []
        },
        {
          "name": "Restock Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"product_id\": \"d290f1ee-6c54-4b01-90e6-d701748f0851\",\n    \"quantity\": 50\n}"
            },
            "url": {
              "raw": "{{base_url}}/products/restock",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "products",
                "restock"
              ]
            },
            "description": "Adds more stock to an existing product."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Purchase Product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"product_id\": \"d290f1ee-6c54-4b01-90e6-d701748f0851\",\n    \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Creates an order for a product, reducing its stock."
          },
          "response": []
        }
      ]
